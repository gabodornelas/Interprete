$- 1. Palabras Clave de Creacion y Control -$
create bot on activation end
execute activate advance deactivate deactivation

$- 2. Palabras Clave de Flujo y Acciones -$
if else while
store collect receive as drop
left right up down read send default

$- 3. Tipos de Datos y Literales Booleanos -$
bool int char true false

$- 4. Literales Numericos -$
0 1 42 9999 

